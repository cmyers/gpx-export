{
  "name": "gpx-export",
  "version": "0.0.1",
  "author": "Chris Myers <cmyers2015@outlook.com> (https://www.npmjs.com/~cmyers-dev)",
  "description": "Export to GPX format from GPS data",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gps",
    "gpx",
    "export",
    "gpx-generator",
    "track",
    "coordinates",
    "geolocation",
    "xml",
    "zero-dependency",
    "cross-platform",
    "browser",
    "web",
    "ionic",
    "capacitor",
    "node",
    "typescript",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cmyers/gpx-export.git"
  },
  "homepage": "https://github.com/cmyers/gpx-export#readme",
  "bugs": {
    "url": "https://github.com/cmyers/gpx-export/issues"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.6",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}